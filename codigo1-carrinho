#include <Ultrasonic.h>

#define TRIG_PIN 15
#define ECHO_PIN 14

Ultrasonic ultrasonic(TRIG_PIN, ECHO_PIN);

void setup() {
  Serial.begin(9600);
}

void loop() {
  int distancia = ultrasonic.read(); // distância em cm

  Serial.print("Distancia: ");
  Serial.print(distancia);
  Serial.println(" cm");
  delay(100);
}
