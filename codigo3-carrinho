#include <AFMotor_R4.h>
#include <Ultrasonic.h>

// Cria os motores (M1, M2, M3, M4)
AF_DCMotor motor1(1);
AF_DCMotor motor2(2);
AF_DCMotor motor3(3);
AF_DCMotor motor4(4);

// Define pinos do sensor ultrassônico
#define TRIG_PIN 15
#define ECHO_PIN 14

Ultrasonic ultrasonic(TRIG_PIN, ECHO_PIN);

void setup() {
  Serial.begin(9600);

  // Define velocidade (0 a 255)
  motor1.setSpeed(200);
  motor2.setSpeed(200);
  motor3.setSpeed(200);
  motor4.setSpeed(200);
}

void loop() {
  int distancia = ultrasonic.read(); // distância em cm

  Serial.print("Distancia: ");
  Serial.print(distancia);
  Serial.println(" cm");
  if (distancia <= 30) {
    // PARA os motores
    motor1.run(RELEASE);
    motor2.run(RELEASE);
    motor3.run(RELEASE);
    motor4.run(RELEASE);
  } else {
    // TODOS PARA FRENTE
    motor1.run(FORWARD);
    motor2.run(FORWARD);
    motor3.run(FORWARD);
    motor4.run(FORWARD);
  }

  delay(100);
}
